{
    "experiment_name": "swin_b_dynamic_unfreeze",
    "model": {
        "backbone": "swin_b",
        "pretrained": true,
        "freeze_backbone": true,
        "classifier_hidden": [1024],
        "dropout": 0.3
    },
    "data": {
        "path": "/scratch/hl98745/category_balanced_dataset",
        "input_size": 224,
        "batch_size": 64,
        "num_workers": 8
    },
    "augmentations": {
        "horizontal_flip": true,
        "vertical_flip": false,
        "random_rotation": 15,
        "color_jitter": 0.1,
        "random_crop_scale": [0.8, 1.0]
    },
    "training": {
        "epochs": 100,
        "learning_rate": 0.001,
        "optimizer": "adamw",
        "weight_decay": 0.01,
        "scheduler": "cosine",
        "seed": 42,
        "early_stopping_patience": 20,
        "dynamic_unfreeze": {
            "unfreeze_patience": 8,
            "unfreeze_size": 1,
            "lr_decay_ratio": 0.1
        }
    }
}
