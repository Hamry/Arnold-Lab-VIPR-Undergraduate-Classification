{
    "study_name": "alexnet_dynamic_unfreeze_sweep",
    "base_config_path": "configs/alexnet_dynamic_unfreeze.json",
    "n_trials": 20,
    "timeout_hours": 12,
    "pruning": {
        "enabled": true,
        "n_startup_trials": 5,
        "n_warmup_steps": 0,
        "percentile": 25.0
    },
    "cleanup": {
        "keep_top_n": 5,
        "cleanup_frequency": 10
    },
    "search_space": {
        "training.learning_rate": {
            "type": "log_float",
            "low": 1e-4,
            "high": 1e-3
        },
        "training.dynamic_unfreeze.lr_decay_ratio": {
            "type": "log_float",
            "low": 0.01,
            "high": 0.5
        },
        "training.dynamic_unfreeze.unfreeze_patience": {
            "type": "int",
            "low": 3,
            "high": 15
        }
    }
}
